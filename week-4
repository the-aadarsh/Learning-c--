#include <iostream>

using namespace std;

// Function overloading allows multiple functions with the same name 
// but different parameter lists (number or type of arguments).
// Note: It does not depend on the return type.

// Same: Function name (add)
// Different: Parameter lists

int add(int a, int b) {
    return a + b;
}

int add(int a, int b, int c) {
    return a + b + c;
}

// OPTIMIZATION: Changed return type from 'int' to 'float' to preserve decimals
float add(float a, float b) {
    return a + b;
}

int main() {
    int res;
    
    res = add(1, 2);
    // Added spaces before the closing quote for readability
    cout << "The value of addition of two numbers is: " << res << endl;
    
    res = add(10, 20, 30);
    cout << "The value of addition of three numbers is: " << res << endl;
    
    float res2;
    res2 = add(1.5f, 2.5f);
    cout << "The value of addition of two float numbers is: " << res2 << endl;
    
    return 0;
}
